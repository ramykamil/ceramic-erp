# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ceramic_erp
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Backup Configuration
# BACKUP_DIR=C:\Backups\CeramicERP
BACKUP_SCHEDULE=0 17 * * *
# Schedule format (cron): minute hour day-of-month month day-of-week
# Examples:
#   0 0 * * *    = Every day at midnight
#   0 17 * * *   = Every day at 5:00 PM
#   0 */6 * * *  = Every 6 hours
